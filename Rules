rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow logged-in students to write their own tickets
    match /supportTickets/{ticket} {
      allow read, write: if request.auth != null;
    }
    // Allow reading student profiles
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
