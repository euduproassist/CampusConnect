rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /supportTickets/{ticket} {
      // Allow create if authenticated
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      
      // Allow read only if the ticket belongs to the user
      allow read: if request.auth != null && resource.data.studentId == request.auth.uid;
      
      // Disable update/delete for students to prevent tampering
      allow update, delete: if false; 
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

